rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net default catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Pointers & Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Role-based Access Control checking Firestore document OR verified bootstrap emails
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email_verified == true && request.auth.token.email in ['idsystems17@gmail.com', 'liviston63@gmail.com'])
      );
    }

    function isValidDayId(dayId) {
      return dayId.size() >= 1 && dayId.size() <= 3 && dayId.matches('^[0-9]+$');
    }

    // Schema Validation Helper
    function isValidDevotional(data) {
      return data.keys().hasAll(['day', 'title', 'verseText', 'verseReference', 'reflection', 'action', 'prayer', 'category'])
        && data.keys().size() <= 10
        && data.day is int
        && data.day >= 1
        && data.day <= 365
        && data.title is string
        && data.title.size() <= 200
        && data.verseText is string
        && data.verseText.size() <= 1000
        && data.verseReference is string
        && data.verseReference.size() <= 200
        && data.reflection is string
        && data.reflection.size() <= 5000
        && data.action is string
        && data.action.size() <= 1000
        && data.prayer is string
        && data.prayer.size() <= 1000
        && data.category is string
        && data.category.size() <= 1005;
    }

    // Devotionals Collection Matching Rules
    match /devotionals/{dayId} {
      // Public reading allows unrestricted viewing for church members
      allow get, list: if true;

      // Administrative editing
      allow create: if isAdmin() 
        && isValidDayId(dayId) 
        && isValidDevotional(incoming());

      allow update: if isAdmin()
        && isValidDevotional(incoming())
        && incoming().day == existing().day
        && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'verseText', 'verseReference', 'reflection', 'action', 'prayer', 'category', 'lastEditedBy', 'lastEditedAt']);

      allow delete: if isAdmin();
    }

    // Admins Registry
    match /admins/{adminUid} {
      allow read: if isSignedIn() && (request.auth.uid == adminUid || isAdmin());
      allow write: if isAdmin();
    }

    // Schema validation for a member's synced reading progress
    function isValidUserSettings(data) {
      return data.keys().hasOnly(['notificationTime', 'notificationsEnabled', 'readDays', 'starredDays'])
        && (!('notificationTime' in data) || data.notificationTime is string)
        && (!('notificationsEnabled' in data) || data.notificationsEnabled is bool)
        && (!('readDays' in data) || (data.readDays is list && data.readDays.size() <= 365))
        && (!('starredDays' in data) || (data.starredDays is list && data.starredDays.size() <= 365));
    }

    // Per-member reading progress (Marcar como Lido / Favoritos), synced across devices
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId && isValidUserSettings(incoming());
    }

    // Schema validation for a member's prayer request submission
    function isValidPrayerRequest(data) {
      return data.keys().hasOnly(['name', 'request', 'createdAt'])
        && data.name is string && data.name.size() <= 200
        && data.request is string && data.request.size() >= 1 && data.request.size() <= 2000
        && data.createdAt is string;
    }

    // Prayer requests: anyone can submit (anonymous or not), only the pastor can read them
    match /prayer_requests/{requestId} {
      allow create: if isValidPrayerRequest(incoming());
      allow get, list: if isAdmin();
    }
  }
}
